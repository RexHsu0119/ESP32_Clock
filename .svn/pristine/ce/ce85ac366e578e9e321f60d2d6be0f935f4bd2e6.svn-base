{
  // --- 1. ESP-IDF 核心環境路徑設定 ---
  "idf.espIdfPathWin": "D:/Espressif/frameworks/esp-idf-v5.5/",
  "idf.pythonInstallPath": "D:\\Espressif\\tools\\idf-python\\3.11.2\\python.exe",
  "idf.toolsPathWin": "D:\\Espressif",
  "idf.currentSetup": "D:/Espressif/frameworks/esp-idf-v5.5/",
  
  // --- 2. 硬體與燒錄設定 ---
  "idf.portWin": "COM11",
  "idf.openOcdConfigs": [
    "board/esp32s3-builtin.cfg"
  ],
  "idf.flashBaudRate": "921600",
  "idf.monitorBaudRate": "115200",
  "idf.flashType": "UART",
  "idf.customExtraVars": {
    "IDF_TARGET": "esp32s3",
    "IDF_TOOLCHAIN": "gcc"
  },

  // --- 3. 程式碼提示 (IntelliSense) 與格式化設定 ---
  // 建議：既然你已經設定了 c_cpp_properties.json，就專心使用微軟的 C/C++ 擴充套件
  // 關閉 clangd 避免兩個語法引擎互相打架
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.errorSquiggles": "enabled",
  "clangd.enabled": false,

  // --- (如果你非要用 clangd，請把上面的 C_Cpp.intelliSenseEngine 設為 "disabled"，並使用相對路徑) ---
  "clangd.path": "D:\\Espressif\\tools\\esp-clang\\esp-19.1.2_20250312\\esp-clang\\bin\\clangd.exe",
  "clangd.arguments": [
    "--background-index",
    "--query-driver=D:\\Espressif\\tools\\xtensa-esp-elf\\esp-14.2.0_20241119\\xtensa-esp-elf\\bin\\xtensa-esp32s3-elf-gcc.exe",
    "--compile-commands-dir=${workspaceFolder}/build" // 優化：改成 ${workspaceFolder} 避免寫死絕對路徑
  ],

  // --- 4. 編輯器行為 ---
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "ms-vscode.cpptools",
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.formatOnSave": true
  },

  // --- 5. 隱藏不必要的文件以保持檔案總管整潔 ---
  "files.exclude": {
    "**/build": true,
    "**/.git": true,
    "**/.history": true
  }
}